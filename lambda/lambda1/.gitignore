# Terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude sensitive variable files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file (optional)
.terraform.lock.hcl

# CLI config files
terraform.rc
.terraformrc

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# ZIP files
*.zip

# Python cache
__pycache__/
*.pyc